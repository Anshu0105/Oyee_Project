MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/oyee
PORT=5002
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your_super_secret_jwt_key_here

# Optional for local dev: if unset, OTP is printed in the backend terminal (NODE_ENV !== production).
# For production email, set all four SMTP_* values (Gmail: use an App Password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Set to true to force console OTP even in production (not recommended).
# OTP_DEV_MODE=false
